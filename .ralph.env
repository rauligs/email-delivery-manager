# Ralph configuration. Sourced by ./ralph.sh at startup.
# Edit any value here to change settings persistently - no need to re-run setup.

# Developer and QA must be different providers: claude, gemini, or codex.
DEVELOPER_AGENT=claude
QA_AGENT=gemini

# Leave model empty to use the provider CLI default/latest model for your
# installed CLI and account. Set a model id only when you need to override/pin.
DEVELOPER_MODEL=''
QA_MODEL=''

# Codex developer runs may need local resources such as Docker for verification.
CODEX_SANDBOX=danger-full-access

# Codex reasoning effort split:
# - Manual Codex planning, PRD, issue creation, and QA use high reasoning.
# - Codex implementation and final-QA fix runs use medium reasoning.
CODEX_DEVELOPER_REASONING_EFFORT=medium
CODEX_QA_REASONING_EFFORT=high
CODEX_PLANNING_REASONING_EFFORT=high

# Claude effort split:
# - Manual Claude planning, PRD, issue creation, and QA use high effort.
# - Claude implementation and final-QA fix runs use medium effort.
CLAUDE_DEVELOPER_EFFORT=medium
CLAUDE_QA_EFFORT=high
CLAUDE_PLANNING_EFFORT=high

# Repo-level verification contract. Ralph uses this before committing.
# Keep this script deterministic and make it run every required project check.
VERIFY_CMD=./scripts/verify.sh

# Docker disclosure for verification: auto, 1, or 0.
# auto notes Docker when verify scripts or compose files indicate it.
ALLOW_DOCKER=auto

# Automatic developer fix attempts after failed final QA verdicts.
MAX_QA_FIXES=2

# Maximum final-QA stdin payload bytes sent to any reviewer CLI.
QA_DIFF_MAX_BYTES=900000

# Advanced QA override. Leave empty to use QA_AGENT/QA_MODEL. If set, this
# command must accept the cumulative diff on stdin and end with PASS or FAIL.
QA_CMD=''

# Other tunables:
# MAX_ITERATIONS=20
# PERMISSION_MODE=acceptEdits  # Claude developer only
